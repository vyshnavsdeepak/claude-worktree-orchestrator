# Claude Worktree Orchestrator — example config
# Copy to cwo.toml and fill in your values.

# Tmux session where worker windows live
session = "my-workers"

# GitHub repo (owner/name)
repo = "owner/repo"

# GitHub issue number used as the product discussion thread
discussion_issue = 1

# Git repo root (absolute path)
repo_root = "/path/to/repo"

# Tmux binary
tmux = "/opt/homebrew/bin/tmux"

# Worktree base dir (relative to repo_root)
worktree_dir = ".claude/worktrees"

# Feature branch prefix
branch_prefix = "feature/issue-"

# Window name prefix for issue workers
window_prefix = "issue-"

# Shell prompt patterns to detect "idle shell" state
# Add your username or shell prompt prefix here.
shell_prompts = ["$ ", ">> "]

# How many Claude workers can run concurrently
max_concurrent = 3

# Seconds between builder discussion-scan cycles
builder_sleep_secs = 300

# Seconds between poller ticks
poll_interval_secs = 1

# ─── Merge & Review Policy ───────────────────────────────────────────────────

# Merge policy: "auto" | "review_then_merge" | "manual"
#   auto              — merge CLEAN PRs immediately (default)
#   review_then_merge — spawn AI reviewer, wait for APPROVED before merge
#   manual            — never auto-merge, just monitor and notify
merge_policy = "auto"

# Spawn AI reviewers for new PRs
auto_review = true

# Review timeout in seconds (merge anyway after this, 0 = wait forever)
review_timeout_secs = 600

# ─── Worker Health ────────────────────────────────────────────────────────────

# Auto-relaunch crashed workers (Claude exited to shell)
auto_relaunch = true

# Max relaunch attempts before marking worker as permanently failed
max_relaunch_attempts = 3

# Mark worker stale if no output changes for this many seconds (0 = disabled)
stale_timeout_secs = 300
